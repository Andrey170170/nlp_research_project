{
  "defaults": {
    "prompts": 1,
    "completions": 1,
    "temperature": 0.0,
    "max_steps": 1,
    "max_feature_nodes": 8192,
    "max_edges": 20000,
    "max_n_logits": 3,
    "desired_logit_prob": 0.8,
    "verbose_attribution": true,
    "profile_attribution": true,
    "profile_log_interval": 1,
    "attribution_update_interval": 4,
    "save_raw": false,
    "no_offload": false,
    "timeout_minutes": 45
  },
  "scenarios": [
    {
      "name": "chunk256_batch32",
      "decoder_chunk_size": 256,
      "attribution_batch_size": 32
    },
    {
      "name": "chunk512_batch32",
      "decoder_chunk_size": 512,
      "attribution_batch_size": 32
    },
    {
      "name": "chunk1024_batch32",
      "decoder_chunk_size": 1024,
      "attribution_batch_size": 32
    },
    {
      "name": "chunk1024_batch16",
      "decoder_chunk_size": 1024,
      "attribution_batch_size": 16
    }
  ]
}
